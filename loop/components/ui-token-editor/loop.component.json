{
  "schemaVersion": "1",
  "kind": "component",
  "id": "ui-token-editor",
  "name": "UI Token Editor",
  "version": "0.1.0",
  "description": "Design token editor panel for theme reskin workflows.",
  "files": [
    {
      "source": "files/TokenEditorPanel.tsx",
      "target": "src/components/ui-demo/TokenEditorPanel.tsx"
    }
  ],
  "patches": [],
  "dependencies": [
    {
      "name": "@loop-kit/ui",
      "version": "workspace:*",
      "type": "dependencies"
    }
  ],
  "targets": ["app", "pkg"],
  "metadata": {
    "tags": ["ui", "tokens", "editor", "theme"],
    "source": "packages/ui/src/blocks/token-editor",
    "localCommands": {
      "addDev": "pnpm run loop:dev add local:ui-token-editor --to apps/ui-demo --cwd .",
      "addDist": "node packages/loop-cli/dist/cli.js add local:ui-token-editor --to apps/ui-demo --cwd .",
      "show": "pnpm run loop:dev component show ui-token-editor --cwd ."
    }
  }
}
