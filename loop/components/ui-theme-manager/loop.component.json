{
  "schemaVersion": "1",
  "kind": "component",
  "id": "ui-theme-manager",
  "name": "UI Theme Manager",
  "version": "0.1.0",
  "description": "Theme preset/mode manager panel for docked UI demos.",
  "files": [
    {
      "source": "files/ThemeManagerPanel.tsx",
      "target": "src/components/ui-demo/ThemeManagerPanel.tsx"
    }
  ],
  "patches": [],
  "dependencies": [
    {
      "name": "@loop-kit/ui",
      "version": "workspace:*",
      "type": "dependencies"
    },
    {
      "name": "@loop-kit/graphite",
      "version": "workspace:*",
      "type": "dependencies"
    }
  ],
  "targets": ["app", "pkg"],
  "metadata": {
    "tags": ["ui", "theme", "tokens", "demo"],
    "source": "packages/ui/src/blocks/theme-manager",
    "localCommands": {
      "addDev": "pnpm run loop:dev add local:ui-theme-manager --to apps/ui-demo --cwd .",
      "addDist": "node packages/loop-cli/dist/cli.js add local:ui-theme-manager --to apps/ui-demo --cwd .",
      "show": "pnpm run loop:dev component show ui-theme-manager --cwd ."
    }
  }
}
