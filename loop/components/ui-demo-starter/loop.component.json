{
  "schemaVersion": "1",
  "kind": "component",
  "id": "ui-demo-starter",
  "name": "UI Demo Starter",
  "version": "0.1.0",
  "description": "Starter bundle for the full docked UI demo experience.",
  "files": [
    {
      "source": "files/UiDemoStarter.tsx",
      "target": "src/components/ui-demo/UiDemoStarter.tsx"
    }
  ],
  "patches": [],
  "dependencies": [
    {
      "name": "@loop-kit/ui",
      "version": "workspace:*",
      "type": "dependencies"
    },
    {
      "name": "@loop-kit/dock",
      "version": "workspace:*",
      "type": "dependencies"
    },
    {
      "name": "@loop-kit/graphite",
      "version": "workspace:*",
      "type": "dependencies"
    }
  ],
  "targets": ["app"],
  "metadata": {
    "tags": ["ui", "starter", "dock", "demo", "bundle"],
    "source": "packages/ui/src/blocks",
    "includes": [
      "ui-dock-workspace",
      "ui-theme-manager",
      "ui-token-editor",
      "ui-shortcuts-settings"
    ],
    "localCommands": {
      "addDev": "pnpm run loop:dev add local:ui-demo-starter --to apps/ui-demo --cwd .",
      "addDist": "node packages/loop-cli/dist/cli.js add local:ui-demo-starter --to apps/ui-demo --cwd .",
      "show": "pnpm run loop:dev component show ui-demo-starter --cwd ."
    }
  }
}
