# Copy to .env.registry before running Dagger + Nitric deploy flows.
# This file is loaded by dotenvx in Dagger registry functions.

NITRIC_STACK=gcp-main
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_REGION=us-central1

# If you use workload identity or an external auth helper, you may not need this.
# GOOGLE_APPLICATION_CREDENTIALS=/workspace/examples/nitric/loop-registry/.secrets/gcp-service-account.json
